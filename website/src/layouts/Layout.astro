---
interface Props {
  title?: string;
}

const { title = "Tipi" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tipi - Quickly find and jump back to websites from browser history. A fast keyboard-first browser extension for Chrome, Edge, Arc, and Firefox." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Work+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}logo.png`} />
  </head>
  <body>
    <slot />
  </body>
</html>
